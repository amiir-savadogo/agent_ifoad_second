# ============================================================
# FICHIER DE CONFIGURATION - VARIABLES D'ENVIRONNEMENT
# ============================================================
# INSTRUCTIONS :
# 1. Copier ce fichier : cp .env.exemple .env
# 2. Remplir les valeurs ci-dessous
# 3. Ne JAMAIS commit le fichier .env sur GitHub !
# ============================================================

# --- CLÉ API GROQ (OBLIGATOIRE) ---
# Obtenir gratuitement sur : https://console.groq.com
# Créer un compte → "API Keys" → "Create API Key"
# Aucune carte bancaire requise !
CLE_API_GROQ=votre_cle_api_groq_ici

# --- MODÈLE LLM À UTILISER ---
# Modèles disponibles gratuitement sur Groq (juin 2026) :
# - openai/gpt-oss-120b       → Le plus performant (recommandé)
# - qwen/qwen3.6-27b          → Bon équilibre vitesse/qualité
# - openai/gpt-oss-20b        → Le plus rapide pour les tests
MODELE_LLM=openai/gpt-oss-120b

# --- MODÈLE D'EMBEDDINGS (LOCAL, GRATUIT) ---
# Pas besoin d'API, tourne entièrement sur votre machine
# Ce modèle supporte le français et les langues africaines
MODELE_EMBEDDINGS=paraphrase-multilingual-mpnet-base-v2

# --- MODÈLE DE RE-RANKING (LOCAL, GRATUIT) ---
# Cross-encoder pour améliorer la précision des résultats
MODELE_RERANKING=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- CHEMINS DES DONNÉES ---
CHEMIN_DONNEES_BRUTES=data/brut
CHEMIN_BASE_VECTORIELLE=data/vectorielle
NOM_COLLECTION_CHROMA=ifoad_ujkz_collection

# --- PARAMÈTRES DE SCRAPING ---
# URL principale du site UJKZ contenant les informations IFOAD
URL_UJKZ=https://www.ujkz.bf
# Délai entre chaque requête (secondes) - pour ne pas surcharger le serveur
DELAI_SCRAPING=2

# --- PARAMÈTRES RAG ---
# Taille des morceaux de texte (en tokens)
TAILLE_CHUNK=500
# Chevauchement entre morceaux consécutifs (en tokens)
CHEVAUCHEMENT_CHUNK=100
# Nombre de documents récupérés par recherche dense
NOMBRE_DOCS_DENSE=10
# Nombre de documents récupérés par BM25
NOMBRE_DOCS_BM25=10
# Nombre de documents après re-ranking (envoyés au LLM)
NOMBRE_DOCS_FINAL=5

# --- PARAMÈTRES DE L'INTERFACE ---
TITRE_APPLICATION=Assistant IFOAD-UJKZ
SOUS_TITRE=Votre guide intelligent pour les formations à distance
